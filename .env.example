# Get API_ID and API_HASH from https://my.telegram.org/apps
API_ID=12345678
API_HASH=your_api_hash_here

# Secret key for API (header X-API-Key)
API_KEY=your_secret_api_key_here

# Use Telegram test servers
TEST_MODE=False

# Directory for .session files (created automatically)
SESSIONS_DIR=sessions_data

# Server
HOST=0.0.0.0
PORT=3579
LOG_LEVEL=INFO
